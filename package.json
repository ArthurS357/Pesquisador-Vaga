{
  "name": "pesquisa-emprego",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "collect": "prisma db push --schema=schema.prisma --skip-generate && cross-env NODE_OPTIONS=--use-system-ca tsx src/cli.ts",
    "start:worker": "cross-env NODE_OPTIONS=--use-system-ca tsx src/worker.ts",
    "db:push": "prisma db push --schema=schema.prisma",
    "db:reset": "tsx -e \"import('fs').then(f=>f.rmSync('dev.db',{force:true}))\" ; prisma db push --schema=schema.prisma",
    "db:clean": "tsx src/db-clean.ts",
    "ollama:start": "powershell -ExecutionPolicy Bypass -File scripts/start-ollama.ps1",
    "ollama:status": "powershell -ExecutionPolicy Bypass -File scripts/ollama-status.ps1",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^25.9.3",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "prisma": "^5.22.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "imapflow": "^1.4.1",
    "mailparser": "^3.9.10",
    "next": "^16.2.9",
